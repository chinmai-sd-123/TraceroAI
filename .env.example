# Postgres (note the +psycopg driver). All app settings use the TRACEROAI_ prefix.
TRACEROAI_DATABASE_URL=postgresql+psycopg://traceroai:traceroai@localhost:5432/traceroai
TRACEROAI_ENV=development

# LLM judge (deep eval). Leave the key empty to run deterministic-only.
# Works with OpenAI OR any OpenAI-compatible endpoint (e.g. Gemini) via JUDGE_BASE_URL.
TRACEROAI_OPENAI_API_KEY=sk-...
TRACEROAI_JUDGE_MODEL=gpt-4o-mini
# TRACEROAI_JUDGE_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
TRACEROAI_DEEP_EVAL_ENABLED=true

# Redis (async deep-eval queue + rate limiter). Optional locally.
TRACEROAI_REDIS_URL=redis://localhost:6379/0

# Multi-tenant lite: map SDK API keys to project ids (JSON object).
# Each authenticated ingest is stamped with the key's project; the dashboard
# filters by project. Unknown/absent keys keep the client-provided project.
TRACEROAI_PROJECT_API_KEYS={"key_acme":"acme","key_globex":"globex"}
# Reject ingest without a known key (writes only; reads stay open). Default false.
TRACEROAI_REQUIRE_API_KEY=false

# CORS allow-list for the web app (comma/JSON list). Empty = none added.
TRACEROAI_CORS_ORIGINS=["http://localhost:3000"]
