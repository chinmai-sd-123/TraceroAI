# Copy to .env and fill in. (.env is gitignored — never commit your real key.)

# OpenAI — used by the recovery example's retriever (embeddings) + generator.
OPENAI_API_KEY=sk-...

# Where to send traces. Use the live API, or http://127.0.0.1:8000 for local.
TRACEROAI_API_URL=https://traceroai.onrender.com

# Optional — scopes the traces to a project on the dashboard.
TRACEROAI_API_KEY=
